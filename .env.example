# OpenUI5 Theme Designer - Environment Variables Configuration

# =============================================================================
# OAuth / Keycloak Configuration
# =============================================================================

# Keycloak Server URL (e.g., https://keycloak.example.com)
KEYCLOAK_URL=https://your-keycloak-server.com

# Keycloak Realm Name
KEYCLOAK_REALM=your-realm

# OAuth Client ID (registered in Keycloak)
CLIENT_ID=theme-designer

# OAuth Client Secret (from Keycloak client configuration)
CLIENT_SECRET=your-client-secret-here

# Session Secret (generate with: openssl rand -hex 32)
SESSION_SECRET=your-session-secret-here

# =============================================================================
# Theme Builder Configuration
# =============================================================================

# Theme Builder URLs - JSON mapping of UI5 versions to Builder API URLs
# Format: {"version":"url","version":"url"}
# Internal Docker network URLs (when using docker-compose)
THEME_BUILDER_URLS={"1.96.40":"http://theme-builder-1-96:3000","1.120.20":"http://theme-builder-1-120:3000"}

# Default UI5 Version (used when theme has no version specified)
DEFAULT_UI5_VERSION=1.96.40

# =============================================================================
# Database Configuration
# =============================================================================

# SQLite Database Path (relative to theme-designer-app/server)
DATABASE_PATH=/app/server/data/themes.db

# =============================================================================
# Application Configuration
# =============================================================================

# Node Environment (development | production)
NODE_ENV=production

# =============================================================================
# Notes
# =============================================================================
#
# To add a new UI5 version:
# 1. Create package-{version}.json in theme-builder-api/
# 2. Add new service to docker-compose.yml (e.g., theme-builder-1-130)
# 3. Update THEME_BUILDER_URLS to include new version mapping
# 4. Update frontend dropdown in webapp/view/NewThemeDialog.fragment.xml
#
# Session Secret Generation:
#   openssl rand -hex 32
#
# OAuth Client Setup (Keycloak):
# 1. Create new client in Keycloak admin console
# 2. Set Access Type to "confidential"
# 3. Add Valid Redirect URIs: https://your-domain.com/auth/callback
# 4. Copy Client Secret from Credentials tab
#
