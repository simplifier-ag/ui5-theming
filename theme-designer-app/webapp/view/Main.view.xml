<mvc:View
	controllerName="themedesigner.controller.Main"
	displayBlock="true"
	height="100%"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:l="sap.ui.layout"
	xmlns:f="sap.f"
	xmlns:core="sap.ui.core"
	xmlns:custom="themedesigner.control"
	xmlns:editor="sap.ui.codeeditor"
	xmlns:unified="sap.ui.unified">

	<f:DynamicPage
		id="dynamicPageId"
		headerExpanded="true"
		toggleHeaderOnTitleClick="false"
		fitContent="true">
		<!-- DynamicPage Title -->
		<f:title>
			<f:DynamicPageTitle>
				<f:heading>
					<Title text="{themeModel>/name}" />
				</f:heading>
				<f:actions>
					<Button
						text="Save"
						type="Emphasized"
						press="onSaveTheme"
						enabled="{themeModel>/isModified}" />
					<Button
						text="Export"
						type="Default"
						press="onExport" />
					<Button
						text="Reset"
						press="onReset" />
				</f:actions>
			</f:DynamicPageTitle>
		</f:title>
		<!-- DynamicPage Content -->
		<f:content>
			<l:Splitter height="100%">
				<!-- Preview Panel (Left Side) -->
				<Panel headerText="Preview" expandable="false" height="100%">
					<layoutData>
						<l:SplitterLayoutData size="auto" />
					</layoutData>
					<content>
						<VBox width="100%" height="100%" class="previewContainer" id="previewContainer" busyIndicatorDelay="0">
							<custom:PreviewFrame id="previewFrame" src="preview.html" />
						</VBox>
					</content>
				</Panel>

				<!-- Controls Panel (Right Side) -->
				<ScrollContainer
					height="100%"
					width="100%"
					vertical="true"
					horizontal="false">
					<layoutData>
						<l:SplitterLayoutData size="380px" />
					</layoutData>
					<VBox class="sapUiContentPadding">

						<!-- Theme Settings Panel -->
						<Panel headerText="Theme Settings" expandable="false">
							<VBox class="sapUiSmallMargin">
								<Label text="Display Name" />
								<Input
									id="themeName"
									value="{themeModel>/name}"
									placeholder="My Custom Theme"
									width="100%"
									liveChange="onThemeNameChange" />

								<Label text="Technical ID" class="sapUiSmallMarginTop" />
								<Input
									id="themeId"
									value="{themeModel>/themeId}"
									placeholder="my_custom_theme"
									width="100%"
									liveChange="onThemeIdChange" />

								<Label text="Base Theme" class="sapUiSmallMarginTop" />
								<Text text="{themeModel>/baseTheme}" />

								<Label text="Description" class="sapUiSmallMarginTop" />
								<TextArea
									id="themeDescription"
									value="{themeModel>/description}"
									placeholder="Optional description"
									rows="3"
									width="100%"
									liveChange="onDescriptionChange" />
							</VBox>
						</Panel>

						<!-- Brand Color Panel -->
						<Panel headerText="Brand Color" expandable="false">
							<VBox class="sapUiSmallMargin">
								<Label text="Brand Color (HEX)" />
								<HBox alignItems="Center">
									<Input
										id="brandColor"
										value="{themeModel>/brandColor}"
										placeholder="#007bff"
										width="200px"
										showValueHelp="true"
										valueHelpRequest="onBrandColorValueHelp"
										change="onBrandColorChange" />
									<core:HTML content="&lt;div style='width: 50px; height: 38px; margin-left: 10px; border: 1px solid #ccc; background-color: {themeModel>/brandColor};'&gt;&lt;/div&gt;" />
								</HBox>

								<Label text="Focus Color (HEX)" class="sapUiSmallMarginTop" />
								<HBox alignItems="Center">
									<Input
										id="focusColor"
										value="{themeModel>/focusColor}"
										placeholder="#0056b3"
										width="200px"
										showValueHelp="true"
										valueHelpRequest="onFocusColorValueHelp"
										change="onFocusColorChange" />
									<core:HTML content="&lt;div style='width: 50px; height: 38px; margin-left: 10px; border: 1px solid #ccc; background-color: {themeModel>/focusColor};'&gt;&lt;/div&gt;" />
								</HBox>

								<Label text="Shell Color (HEX)" class="sapUiSmallMarginTop" />
								<HBox alignItems="Center">
									<Input
										id="shellColor"
										value="{themeModel>/shellColor}"
										placeholder="#354a5f"
										width="200px"
										showValueHelp="true"
										valueHelpRequest="onShellColorValueHelp"
										change="onShellColorChange" />
									<core:HTML content="&lt;div style='width: 50px; height: 38px; margin-left: 10px; border: 1px solid #ccc; background-color: {themeModel>/shellColor};'&gt;&lt;/div&gt;" />
								</HBox>
							</VBox>
						</Panel>

						<!-- Images Panel -->
						<Panel expandable="true" expanded="true" class="sapUiSmallMarginTop">
							<headerToolbar>
								<Toolbar>
									<Title text="Images" level="H4" />
								</Toolbar>
							</headerToolbar>
							<VBox class="sapUiSmallMargin">

								<Label text="App Background" />
								<Select
									id="backgroundImageSelect"
									width="100%"
									class="sapUiTinyMarginBottom"
									selectedKey="{themeModel>/backgroundImage}"
									change="onBackgroundImageChange"
									items="{path: 'themeModel>/imageSelectOptions', templateShareable: false}">
									<core:Item key="{themeModel>key}" text="{themeModel>text}" />
								</Select>

								<List
									id="imagesList"
									noDataText="No images uploaded yet"
									items="{path: 'themeModel>/files', filters: {path: 'type', operator: 'EQ', value1: 'image'}, templateShareable: false}">
									<headerToolbar>
										<Toolbar>
											<Title text="Uploaded Images" level="H5" />
											<ToolbarSpacer />
											<unified:FileUploader
												buttonOnly="true"
												iconOnly="true"
												icon="sap-icon://upload"
												tooltip="Upload image (max 5 MB)"
												mimeType="image/png,image/jpeg,image/gif,image/webp,image/svg+xml"
												change="onUploadImage" />
										</Toolbar>
									</headerToolbar>
									<CustomListItem>
										<HBox justifyContent="SpaceBetween" alignItems="Center" width="100%"
											  class="sapUiSmallMarginTopBottom">
											<VBox class="sapUiSmallMarginBegin">
												<Text text="{themeModel>filename}" />
												<ObjectStatus
													text="{path: 'themeModel>filename', formatter: '.formatLessParam'}"
													state="Information"
													class="sapUiTinyMarginTop" />
											</VBox>
											<HBox>
												<Button
													icon="sap-icon://copy"
													type="Transparent"
													tooltip="Copy LESS parameter name to clipboard"
													press="onCopyLessParam" />
												<Button
													icon="sap-icon://delete"
													type="Transparent"
													tooltip="Delete image"
													press="onDeleteFile" />
											</HBox>
										</HBox>
									</CustomListItem>
								</List>
							</VBox>
						</Panel>

						<!-- Fonts Panel -->
						<Panel expandable="true" expanded="true" class="sapUiSmallMarginTop">
							<headerToolbar>
								<Toolbar>
									<Title text="Fonts" level="H4" />
								</Toolbar>
							</headerToolbar>
							<VBox class="sapUiSmallMargin">
								<List
									id="fontsList"
									noDataText="No fonts uploaded yet"
									items="{path: 'themeModel>/files', filters: {path: 'type', operator: 'EQ', value1: 'font'}, templateShareable: false}">
									<headerToolbar>
										<Toolbar>
											<Title text="Uploaded Fonts" level="H5" />
											<ToolbarSpacer />
											<unified:FileUploader
												buttonOnly="true"
												iconOnly="true"
												icon="sap-icon://upload"
												tooltip="Upload font (.woff, .woff2, .ttf, .otf — max 10 MB)"
												fileType="woff,woff2,ttf,otf"
												change="onUploadFont" />
										</Toolbar>
									</headerToolbar>
									<CustomListItem>
										<HBox justifyContent="SpaceBetween" alignItems="Center" width="100%"
											  class="sapUiSmallMarginTopBottom">
											<VBox class="sapUiSmallMarginBegin">
												<Text text="{themeModel>filename}" />
												<ObjectStatus
												text="{path: 'themeModel>filename', formatter: '.formatFontFamily'}"
												state="Information"
												class="sapUiTinyMarginTop" />
											</VBox>
											<Button
												icon="sap-icon://delete"
												type="Transparent"
												tooltip="Delete font"
												press="onDeleteFile" />
										</HBox>
									</CustomListItem>
								</List>
							</VBox>
						</Panel>

						<!-- Custom CSS Panel -->
						<Panel expandable="true" expanded="false" class="sapUiSmallMarginTop">
							<headerToolbar>
								<Toolbar>
									<Title text="Custom CSS" level="H4" />
									<Button
										icon="sap-icon://sys-help"
										type="Transparent"
										tooltip="Click to show available UI5 Theming Parameters&#x0a;&#x0a;Example:&#x0a;@sapUiBaseText: blue;"
										press="onCssHelpPress" />
									<ToolbarSpacer />
								</Toolbar>
							</headerToolbar>
							<VBox class="sapUiSmallMargin">
								<Label text="Additional LESS/CSS Rules" />
								<editor:CodeEditor
									id="customCss"
									value="{themeModel>/customCss}"
									type="less"
									height="400px"
									width="100%"
									change="onCssChange" />
							</VBox>
						</Panel>

					</VBox>
				</ScrollContainer>
			</l:Splitter>
		</f:content>
	</f:DynamicPage>

</mvc:View>