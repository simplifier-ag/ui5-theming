<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:l="sap.ui.layout"
	xmlns:f="sap.ui.layout.form">

	<Dialog
		id="exportDialog"
		title="Export Theme"
		contentWidth="500px">
		<content>
			<f:SimpleForm
				editable="true"
				layout="ResponsiveGridLayout"
				labelSpanXL="4"
				labelSpanL="4"
				labelSpanM="4"
				labelSpanS="12"
				adjustLabelSpan="false"
				emptySpanXL="0"
				emptySpanL="0"
				emptySpanM="0"
				emptySpanS="0"
				columnsXL="1"
				columnsL="1"
				columnsM="1"
				singleContainerFullSize="false">
				<f:content>
					<Label text="Theme Name" required="true" />
					<Input
						id="exportThemeName"
						value="{exportModel>/themeName}"
						placeholder="my_custom_theme"
						required="true" />

					<Label text="Base Theme" />
					<Select
						id="exportBaseTheme"
						selectedKey="{exportModel>/baseTheme}">
						<items>
							<core:Item key="sap_horizon" text="SAP Horizon" />
							<core:Item key="sap_fiori_3" text="SAP Fiori 3" />
							<core:Item key="sap_fiori_3_dark" text="SAP Fiori 3 – Dark" />
							<core:Item key="sap_fiori_3_hcb" text="SAP Fiori 3 – High Contrast Black" />
							<core:Item key="sap_fiori_3_hcw" text="SAP Fiori 3 – High Contrast White" />
						</items>
					</Select>

					<Label text="Description" />
					<TextArea
						id="exportDescription"
						value="{exportModel>/description}"
						rows="3"
						placeholder="Optional description for your theme" />
				</f:content>
			</f:SimpleForm>
		</content>
		<beginButton>
			<Button
				text="Export"
				type="Emphasized"
				press="onConfirmExport"
				icon="sap-icon://download" />
		</beginButton>
		<endButton>
			<Button
				text="Cancel"
				press="onCancelExport" />
		</endButton>
	</Dialog>

</core:FragmentDefinition>
