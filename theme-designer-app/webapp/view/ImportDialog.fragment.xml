<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:form="sap.ui.layout.form">
	<Dialog
		id="importDialog"
		title="Import Theme"
		contentWidth="500px"
		afterClose="onImportDialogAfterClose">
		<content>
			<form:SimpleForm
				id="importThemeForm"
				editable="true"
				layout="ResponsiveGridLayout"
				labelSpanXL="4"
				labelSpanL="4"
				labelSpanM="12"
				adjustLabelSpan="false"
				emptySpanXL="0"
				emptySpanL="0"
				emptySpanM="0"
				columnsXL="1"
				columnsL="1"
				columnsM="1">
				<form:content>
					<Label text="UI5 Version" required="true" />
					<Select
						id="ui5VersionImportSelect"
						selectedKey="{versions>/selectedVersion}"
						required="true"
						items="{versions>/versions}">
						<core:Item key="{versions>key}" text="{versions>text}" />
					</Select>

					<Label text="Theme ZIP File" required="true" />
					<VBox>
						<HBox alignItems="Center">
							<Button
								id="selectFileBtn"
								text="Select File"
								icon="sap-icon://attachment"
								press="onSelectImportFile" />
							<Text
								id="selectedFileName"
								text="{importDialog>/selectedFileName}"
								class="sapUiSmallMarginBegin" />
						</HBox>
						<Text
							text="Select a .zip file exported from UI5 Theme Designer"
							class="sapUiTinyMarginTop sapUiContentLabelColor" />
					</VBox>
				</form:content>
			</form:SimpleForm>
		</content>
		<beginButton>
			<Button
				id="importBtn"
				text="Import"
				type="Emphasized"
				enabled="{importDialog>/importReady}"
				press="onConfirmImport" />
		</beginButton>
		<endButton>
			<Button
				text="Cancel"
				press="onCancelImport" />
		</endButton>
	</Dialog>
</core:FragmentDefinition>