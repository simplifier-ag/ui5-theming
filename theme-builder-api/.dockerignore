package-lock.json

# Runtime temp directory
temp

# Build artifacts
coverage
.nyc_output

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode
.idea
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Documentation (except README)
*.md
!README.md

# Local config
.env
.env.local

# Test files
test-*.js

# Local dev setup script (not needed in container)
setup.sh